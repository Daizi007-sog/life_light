# Supabase 配置
# 在 Supabase 项目 Dashboard -> Settings -> API 中获取
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Next.js 版本（app/home 等）使用以下变量
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Edge Functions 环境变量（在 Supabase Dashboard -> Edge Functions -> Secrets 中配置）
# 必填：Dify 工作流 API Key（鼓励话语、经文卡片、经文解读、每日鼓励均使用）
DIFY_API_KEY=app-xxx

# 可选：若使用独立的 Dify 工作流，可分别配置
# DIFY_SCRIPTURE_CARD_API_KEY=app-xxx
# DIFY_SCRIPTURE_INTERPRET_API_KEY=app-xxx

# 每日鼓励 Cron 鉴权（daily-encouragement 定时触发时使用）
CRON_SECRET=your-random-secret-string
